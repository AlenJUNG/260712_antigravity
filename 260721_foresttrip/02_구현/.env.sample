# 이 파일을 복사해 ".env" 로 만들고 값을 채우세요.  (cp .env.sample .env)
# .env 는 .gitignore 로 커밋에서 제외됩니다. 절대 커밋하지 마세요.

# ── CLI(poc.js) 전용 자격증명 ───────────────────────────────────────────────
# 서버(server.js)는 이 값을 쓰지 않고 POST /v1/auth/forest-login 으로 받은 값을
# 암호화해 DB에 저장합니다.
ID=숲나들e_아이디
PW=숲나들e_비밀번호

# ── 서버 필수값 (없으면 기동 거부) ──────────────────────────────────────────
# 앱↔백엔드 Bearer 토큰 (ADR-0005). 24자 이상.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
APP_TOKEN=

# 저장 자격증명 암호화 키 (ADR-0002). 16자 이상. 분실 시 재로그인 필요.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# 운영에서는 Windows DPAPI 로 보호한 값을 프로세스 환경으로 주입하고,
# 같은 PC에 평문 키 파일을 두지 마세요.
ENCRYPTION_KEY=

# ── 선택값 ─────────────────────────────────────────────────────────────────
PORT=3000
HEADLESS=1

# 전역 레이트버짓 R (req/min). (ADR-0006)
# PoC scan-nation 이 65~90 req/min 버스트를 세션오류 0으로 통과한 실측이 있으나,
# 버스트 != 24/7 지속이라 그 1/4 수준으로 시작한다. "24h 지속 폴링 무잠금" 통과 후에만 상향.
RATE_LIMIT_PER_MIN=20
# goods 폴 1건의 선차감 추정 비용(예약 1p + 대기 1p + 여유)
GOODS_POLL_COST=3
# 적응형 폴링 주기의 바닥선(초). N_max 산출 기준과 동일.
MIN_POLL_INTERVAL_SEC=180
# 계속 열려 있는 방을 재알림하는 간격(분). 미설정 시 max(30, 폴주기×2)로 자동 산정.
# ⚠ 폴링 주기보다 확실히 커야 한다. 비슷하면 매 폴마다 재알림돼 스로틀이 무력화된다.
# NOTIFY_THROTTLE_MIN=30
# /v1/search 스냅샷을 이 시간(초) 넘게 묵히면 백그라운드 갱신을 큐잉
AVAIL_TTL_SEC=600
# DB 경로 재정의(기본: <프로젝트루트>/data/forest.db)
# DB_PATH=
